# BotFather'dan olingan bot tokeni
BOT_TOKEN=

# Botni admin qilib qo'shgan kanalingiz - username (@masalan_shu) yoki raqamli ID (-100...)
CHANNEL_ID=

# Railway PostgreSQL avtomatik beradigan ulanish satri
DATABASE_URL=

# Tarjima uchun Anthropic API kaliti (Kontakt Plus'da ishlatilgani bilan bir xil bo'lishi mumkin)
ANTHROPIC_API_KEY=

# /status va /check buyruqlariga kirish huquqiga ega Telegram ID'lar, vergul bilan: 123456,789012
ADMIN_IDS=

# Necha daqiqada bir tekshirsin (standart: 20)
POLL_INTERVAL_MINUTES=20
